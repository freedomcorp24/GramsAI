# ── Rebuildable artifacts (regenerated by bootstrap; NEVER commit) ──
# Frontend deps (3.7G) — restore with: bun install
**/node_modules/
# Build outputs — restore with: bun run build / go build
**/dist/
m1/opencode-src/**/dist/
m1/app/**/*.test
# Compiled binaries — rebuilt from source
m1/bin/
m2/gramsai-image/opencode          # 142MB musl opencode binary (see docs to obtain/build)
m2/gramsai-agent/gramsai-agent     # compiled agent (built on M1)
# Logs / caches / scratch
*.log
**/.cache/
**/*.bak
**/*.prehard*
# User content / runtime data (NEVER commit — per-user chats, DEK-encrypted)
m2/data/
**/.bash_history
# Loose one-off patch scripts (historical; not part of deploy)
m2/root-scripts/

# NOTE: .env files ARE committed (private repo, by design). Do NOT add them here.

secrets/
**/env/*.env

# Upstream opencode bloat (not deployed from this repo)
m1/opencode-src/packages/console/
m1/opencode-src/packages/web/
m1/opencode-src/packages/desktop/
**/test/**/fixtures/
**/*.mp4
**/*.mov
**/*.icns
m1/opencode-src/packages/opencode/bin/opencode
m1/opencode-src/nix/
m2/gramsai-agent/agent-src.tar.gz

# editor/patch backups
*.bak-*
*.bak[0-9]*
*.orig
*~
