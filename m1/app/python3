#!/usr/bin/env python3
# Run on M1:  python3 /root/revert_consent.py
# Removes the broken GRAMSAI_CONSENT block (CSS, HTML, JS) from login.html so
# the file is clean and patch_register_consent.py can apply fresh.
import re
F = "/opt/gramsai/app/internal/auth/login.html"
s = open(F).read()
orig = s

if "GRAMSAI_CONSENT" not in s:
    print(".. nothing to revert (already clean)"); print("DONE"); raise SystemExit

# 1) CSS block: from the marker comment through the .lgl-foot rule (ends right before </style>)
s = re.sub(r"  /\* GRAMSAI_CONSENT \*/\n(?:.*\n)*?  \.lgl-foot\{[^\n]*\}\n(?=</style>)", "", s, count=1)

# 2) consent-block HTML (both possible variants: with or without privacy link)
s = re.sub(r'      <div id="consent-block">\n(?:.*\n)*?      </div>\n(?=      <button class="btn" id="go">Sign in</button>)', "", s, count=1)

# 3) modal overlay HTML before </body>
s = re.sub(r'<div id="lgl-ov">\n(?:.*\n)*?</div>\n(?=</body>)', "", s, count=1)

# 4) JS init block (IIFE) before </script> — both old flat and new wrapped variants
s = re.sub(r"\n/\* GRAMSAI_CONSENT \*/\n\(function\(\)\{\n(?:.*\n)*?\}\)\(\);\n\n?(?=</script>)", "", s, count=1)
# old flat variant (first consent patch) just in case
s = re.sub(r"\n/\* GRAMSAI_CONSENT \*/\nvar LGL_TERMS(?:.*\n)*?document\.getElementById\(\"lgl-ov\"\)\.onclick[^\n]*\n", "", s, count=1)

# 5) setMode hook lines
s = re.sub(r'\n    var cb=document\.getElementById\("consent-block"\);[^\n]*\n    if\(login\)\{ var cc=document\.getElementById\("consent"\); if\(cc\)\{ cc\.checked=false; \} \}', "", s, count=1)

# 6) submit gate line
s = re.sub(r'\n    if\(mode!=="login"\)\{ var cc=document\.getElementById\("consent"\);[^\n]*GRAMSAI_CONSENT \*/', "", s, count=1)

open(F, "w").write(s)
print("login.html: removed %d bytes" % (len(orig) - len(s)))
print("GRAMSAI_CONSENT remaining:", s.count("GRAMSAI_CONSENT"))
print("DONE" if "GRAMSAI_CONSENT" not in s else "WARNING: residue remains")
